To build the image: 

cd /home/rps/rpi-image-gen/
./rpi-image-gen build -S ./examples/appkiosk/ -c kiosk.yaml
sudo umount /dev/sdb1 /dev/sdb2
sudo dd if=/home/rps/rpi-image-gen/work/image-myappkioskimage/myappkioskimage.img of=/dev/sdb bs=4M status=progress conv=fsync
sync




