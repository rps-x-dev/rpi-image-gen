[
   {
      "attributes": {
         "PMAPversion": "1.4.2",
         "system_type": "slotted"
      }
   },
   {
      "partitions": [
         {
            "comment": "boot configuration",
            "image": "bootconfig"
         }
      ]
   },
   {
      "slots": {
         "A": {
            "partitions": [
               {
                  "comment": "kernel + device tree + initramfs slot A",
                  "image": "boot_a",
                  "static": {
                     "uuid": "${BOOT_UUID}",
                     "role": "boot"
                  }
               }
            ]
         }
      }
   },
   {
      "slots": {
         "B": {
            "partitions": [
               {
                  "comment": "kernel + device tree + initramfs slot B",
                  "image": "boot_b",
                  "static": {
                     "uuid": "${BOOT_UUID}",
                     "role": "boot"
                  }
               }
            ]
         }
      }
   },
   {
      "encrypted": {
         "luks2": {
            "key_size": ${LUKS_KEYSIZE},
            "cipher": "${LUKS_CIPHER}",
            "hash": "${LUKS_HASH}",
            "label": "OSDATA",
            "uuid": "${CRYPT_UUID}",
            "mname": "osdata_crypt",
            "etype": "partitioned"
         },
         "slots": {
            "A": {
               "partitions": [
                  {
                     "comment": "Encrypted root filesystem slot A",
                     "image": "system_a",
                     "static": {
                        "uuid": "${SYSTEM_UUID}",
                        "role": "system"
                     }
                  }
               ]
            },
            "B": {
               "partitions": [
                  {
                     "comment": "Encrypted root filesystem slot B",
                     "image": "system_b",
                     "static": {
                        "uuid": "${SYSTEM_UUID}",
                        "role": "system"
                     }
                  }
               ]
            }
         },
         "partitions": [
            {
               "comment": "Encrypted user data - shared between slots",
               "image": "persistent"
            }
         ]
      }
   }
]
